# Configuración del pipeline (copia este archivo como .env)

# Cantidad de registros sintéticos a generar
N_USERS=500
N_TRANSACTIONS=5000
N_DETAILS_PER_TRANSACTION=1

# Semilla para reproducibilidad
RANDOM_SEED=42

# Rutas de las capas (relativas a la raíz del proyecto)
DATA_RAW_PATH=data/raw
DATA_BRONZE_PATH=data/bronze
DATA_SILVER_PATH=data/silver
DATA_GOLD_PATH=data/gold

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# DuckDB
DUCKDB_PATH=data/gold/warehouse.duckdb
